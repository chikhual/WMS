# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ─── Base de datos ────────────────────────────────────────────
# Local con Docker: mongodb://localhost:27017/maker-wms
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/maker-wms
MONGODB_URI=mongodb://localhost:27017/maker-wms

# ─── Auth ─────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis (BullMQ jobs) ──────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://<user>:<pass>@<host>:6380
REDIS_URL=redis://localhost:6379

# ─── Storage (Cloudflare R2) ──────────────────────────────────
# S3_ENDPOINT usa la URL de tu bucket R2
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=maker-wms
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=

# ─── Push (Firebase Cloud Messaging) ─────────────────────────
FCM_SERVER_KEY=
