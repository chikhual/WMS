# ============================================================
# Maker WMS — Mobile App (apps/mobile/.env.example)
# ============================================================
# Copia este archivo a `apps/mobile/.env` y rellena los valores.
# NUNCA hacer commit de `.env`.
#
# ⚠️ IMPORTANTE: Expo expone al bundle TODAS las variables que
# empiezan con EXPO_PUBLIC_. Quedan visibles en el código compilado.
# JAMÁS poner secrets aquí — solo URLs, IDs públicos, y flags.
#
# Los secretos para builds nativos (google-services.json, signing
# keys, etc.) se gestionan con `eas secret` en Expo Application
# Services. Ver sección al final.
# ============================================================


# ----- API -----
# URL del backend. En dispositivo físico/red local usa la IP, no localhost:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
EXPO_PUBLIC_API_URL=http://localhost:3000


# ----- MULTI-TENANCY -----
# Modo de captura del tenant en login:
#   manual → el usuario escribe el "código de organización"
#   email  → se infiere del dominio del email (acme@madereria.com → tenant 'madereria')
EXPO_PUBLIC_TENANT_RESOLUTION_MODE=manual

# Tenant default para dev (solo si TENANT_RESOLUTION_MODE permite override)
EXPO_PUBLIC_DEFAULT_TENANT_SLUG=demo


# ----- APP META -----
EXPO_PUBLIC_APP_NAME=Maker WMS
EXPO_PUBLIC_APP_VERSION=0.1.0          # Idealmente desde app.config.ts


# ----- MONITOREO -----
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development


# ----- ESCANEO DE CÓDIGOS -----
# Si en el futuro habilitamos modelo propio YOLOv8 (Fase 2 del ADR-003),
# este flag activa el pipeline custom. Por default usa ML Kit.
EXPO_PUBLIC_USE_CUSTOM_BARCODE_MODEL=false


# ----- DEBUG (solo dev) -----
EXPO_PUBLIC_ENABLE_REACTOTRON=false
EXPO_PUBLIC_LOG_NETWORK_REQUESTS=false


# ============================================================
# SECRETOS PARA BUILDS NATIVOS — NO van en este archivo
# ============================================================
#
# Los siguientes archivos/secrets se gestionan con EAS Secrets:
#
#   eas secret:create --scope project --name GOOGLE_SERVICES_JSON --type file --value ./google-services.json
#   eas secret:create --scope project --name GOOGLE_SERVICES_PLIST --type file --value ./GoogleService-Info.plist
#
# O en eas.json bajo el campo "env" del build profile correspondiente.
#
# Lista de secrets esperados para builds:
#   - GOOGLE_SERVICES_JSON       (Android, Firebase)
#   - GOOGLE_SERVICES_PLIST      (iOS, Firebase)
#   - EXPO_TOKEN                 (CI/CD)
#   - APPLE_TEAM_ID              (iOS signing)
#   - APPLE_APP_STORE_CONNECT_KEY (App Store submission)
#   - ANDROID_KEYSTORE_PASSWORD  (Android signing)
#   - ANDROID_KEY_ALIAS
#   - ANDROID_KEY_PASSWORD
#
# Ver: https://docs.expo.dev/build-reference/variables/
# ============================================================
