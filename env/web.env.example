# ============================================================
# Maker WMS — Web Admin (apps/web/.env.example)
# ============================================================
# Copia este archivo a `apps/web/.env.local` (Next.js usa .env.local).
# NUNCA hacer commit de .env.local.
#
# IMPORTANTE: en Next.js las variables se dividen en dos:
#   - Sin prefijo → solo server-side (API routes, Server Components,
#     Server Actions, middleware). Seguras.
#   - Con prefijo NEXT_PUBLIC_ → se inyectan al bundle del browser.
#     NUNCA poner secrets aquí.
# ============================================================


# ----- NODE -----
NODE_ENV=development


# ----- API BACKEND (server-side) -----
# URL del API que usan las Server Actions / Route Handlers / middleware.
# En Docker o redes internas puede ser distinta a la pública.
API_URL=http://localhost:3000

# Secret compartido con el API para llamadas server-to-server (si aplica).
# Generar con: openssl rand -base64 32
API_INTERNAL_SECRET=<generar>


# ----- AUTH (server-side) -----
# Secret para firmar cookies de sesión / CSRF. Distinto al del API.
# Generar con: openssl rand -base64 32
AUTH_SECRET=<generar>

# URL donde corre esta app web. Usado por NextAuth-style libs y
# por links absolutos en emails server-rendered.
AUTH_URL=http://localhost:3001


# ----- MULTI-TENANCY -----
# Dominio raíz para resolver subdominios de tenant.
# Ej: con ROOT_DOMAIN=makerwms.com, "madereria.makerwms.com" → tenant 'madereria'.
ROOT_DOMAIN=makerwms.local
# Solo en dev: para acceder sin subdominio usando ?tenant=slug en la URL
ALLOW_TENANT_QUERY_PARAM=true


# ============================================================
# PÚBLICAS (NEXT_PUBLIC_*) — visibles en el navegador
# Solo URLs, IDs públicos, flags de UI. NUNCA secrets.
# ============================================================

# URL pública del API (la usa el browser para llamadas fetch directas).
NEXT_PUBLIC_API_URL=http://localhost:3000

# Nombre y branding default (pueden ser sobrescritos por tenant)
NEXT_PUBLIC_APP_NAME=Maker WMS
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@makerwms.com

# Sentry (cliente)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Versión de la app (auto-llenar en CI desde package.json o git sha)
NEXT_PUBLIC_APP_VERSION=0.1.0

# Feature flags de UI (no críticos para seguridad)
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# PostHog / Plausible / etc. para analytics (opcional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
