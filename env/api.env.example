# ============================================================
# Maker WMS — Backend API (apps/api/.env.example)
# ============================================================
# Copia este archivo a `apps/api/.env` y rellena los valores.
# NUNCA hacer commit de `.env` (ya está en .gitignore).
#
# Convención: valores marcados "<generar>" requieren generación
# manual. Usa: `openssl rand -base64 32` para secrets fuertes.
#
# Las llaves de servicios externos POR TENANT (Twilio, Stripe del
# cliente, etc.) NO van aquí — se resuelven en runtime desde el
# secrets manager indexadas por tenantId. Ver ADR-011 en PROJECT.md.
# ============================================================


# ----- SERVER -----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info                      # debug | info | warn | error


# ----- APP META -----
APP_NAME=Maker WMS
APP_URL=http://localhost:3000       # URL pública del propio API
WEB_URL=http://localhost:3001       # URL del panel web (para links en emails)
SUPPORT_EMAIL=soporte@makerwms.com


# ----- DATABASE -----
MONGODB_URI=mongodb://localhost:27017/maker-wms
# Atlas en producción:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/maker-wms?retryWrites=true&w=majority

# DB separada para tests (Vitest)
MONGODB_TEST_URI=mongodb://localhost:27017/maker-wms-test


# ----- AUTH (JWT) -----
# Generar con: openssl rand -base64 32
JWT_SECRET=<generar>
JWT_REFRESH_SECRET=<generar>         # DEBE ser distinto a JWT_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Tokens de un solo uso
PASSWORD_RESET_TOKEN_EXPIRES_IN=1h
EMAIL_VERIFICATION_TOKEN_EXPIRES_IN=24h
INVITATION_TOKEN_EXPIRES_IN=7d

# bcrypt
BCRYPT_ROUNDS=12


# ----- MULTI-TENANCY -----
# Dominio raíz para subdominios de tenant (madereria.<ROOT_DOMAIN>)
ROOT_DOMAIN=makerwms.local           # En prod: makerwms.com

# Modo de resolución del tenant en cada request:
#   subdomain → del Host header (recomendado prod)
#   header    → del header X-Tenant-Slug (recomendado dev)
TENANT_RESOLUTION_MODE=header        # En prod: subdomain

# Para dev: tenant default si no se resuelve uno
DEFAULT_TENANT_SLUG=demo

# Permitir registro público de tenants (false en producción inicial)
ALLOW_TENANT_SELF_REGISTRATION=false


# ----- REDIS (BullMQ jobs + cache) -----
REDIS_URL=redis://localhost:6379
# Upstash en producción:
# REDIS_URL=rediss://default:<pass>@<host>.upstash.io:6379


# ----- STORAGE (S3 o R2) -----
# Provider: 's3' | 'r2'
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=                    # Vacío para S3 estándar; URL para R2/MinIO
STORAGE_REGION=us-east-1
STORAGE_BUCKET=maker-wms-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Prefijo dentro del bucket. {tenantId} se reemplaza en runtime.
STORAGE_KEY_PREFIX={tenantId}/

# URL pública del bucket (CDN o público). Vacío = se generan presigned URLs.
STORAGE_PUBLIC_URL=

# Límite de tamaño de archivo en bytes (10MB default)
UPLOAD_MAX_FILE_SIZE=10485760


# ----- EMAIL (Resend) -----
EMAIL_PROVIDER=resend                # resend | smtp
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@makerwms.com
EMAIL_FROM_NAME=Maker WMS

# Si EMAIL_PROVIDER=smtp (para dev con Mailtrap/MailHog)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false


# ----- PUSH NOTIFICATIONS -----
# Estrategia A — Expo Notifications (recomendado para MVP)
EXPO_ACCESS_TOKEN=

# Estrategia B — Firebase Admin SDK (si se necesita FCM directo)
# Pegar service account como base64: `base64 service-account.json | tr -d '\n'`
FIREBASE_SERVICE_ACCOUNT_BASE64=


# ----- SMS / WHATSAPP (opcional) -----
# Default global. Tenants con cuenta propia: en secrets manager por tenantId.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=


# ----- MONITOREO Y LOGS -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1        # 0.0 - 1.0

# Axiom para logs estructurados (opcional)
AXIOM_TOKEN=
AXIOM_DATASET=maker-wms-api


# ----- JOBS / CRONS -----
# Si true, este proceso corre workers de BullMQ. Permitir false para
# escalar la API y los workers por separado.
ENABLE_BACKGROUND_JOBS=true

# Patrones cron (sintaxis estándar). 'disabled' para desactivar.
CRON_PRODUCTION_SEMAPHORE=0 0 * * *
CRON_AUTO_RESERVATION=*/30 * * * *
CRON_AUDIT_LOG_RETENTION=0 3 * * *   # Limpieza diaria a las 3am


# ----- SEGURIDAD -----
# Orígenes permitidos para CORS (coma-separados, sin espacios)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081

# Rate limiting (express-rate-limit)
RATE_LIMIT_WINDOW_MS=900000           # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100

# Trust proxy (true si está detrás de Nginx/Vercel/Railway)
TRUST_PROXY=false


# ----- FEATURE FLAGS DE PLATAFORMA -----
# Estos son globales (todos los tenants). Los flags POR TENANT viven
# en Tenant.config en la BD (ver PROJECT.md sección 4.3).

MAINTENANCE_MODE=false
ENABLE_SWAGGER_UI=true               # Solo dev; false en producción
ENABLE_API_PLAYGROUND=true           # GraphQL/REST sandbox
