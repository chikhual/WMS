{
  "name": "maker-wms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @maker-wms/api dev",
    "dev:web": "pnpm --filter @maker-wms/web dev",
    "dev:mobile": "pnpm --filter @maker-wms/mobile dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @maker-wms/api build",
    "build:web": "pnpm --filter @maker-wms/web build",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @maker-wms/api test",
    "test:watch": "pnpm --filter @maker-wms/api test:watch",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
